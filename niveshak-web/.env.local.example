# Supabase — required for partner lead capture
# Get these from https://supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Anthropic — optional, only used locally for AI plan explanation
# Route through a server-side function before enabling in production
VITE_ANTHROPIC_API_KEY=sk-ant-...
